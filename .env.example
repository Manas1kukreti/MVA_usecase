# Database
DATABASE_URL=postgresql://mva_user:mva_password@localhost:5432/mva_profiling
DATABASE_ECHO=false

# File Limits
MAX_UPLOAD_SIZE_MB=25
MAX_DATASET_ROWS=200000
MAX_DATASET_COLUMNS=200
PROCESSING_TIMEOUT_SECONDS=120

# Temporary Storage
TEMP_STORAGE_DIR=./tmp/uploads
MAX_SAMPLE_VALUES=10

# Drill-down Cubes
MIN_CUBE_GROUP_SIZE=5
MAX_DRILL_DOWN_LEVELS=5

# LLM Provider
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Schema Intelligence
SCHEMA_INTELLIGENCE_PROVIDER=local

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application
APP_ENV=development
APP_DEBUG=false
API_PREFIX=/api/v1

# Authentication (leave empty to disable)
API_KEYS=[]
JWT_SECRET=
JWT_ALGORITHM=HS256
